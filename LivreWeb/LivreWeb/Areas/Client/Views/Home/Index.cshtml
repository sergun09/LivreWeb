@model IEnumerable<LivreWeb.Models.Livre>

<div class="row pb-3">
    @foreach(Livre livre in Model)
    {
        <a asp-area="Admin" asp-action="Details" asp-route-livreid="@livre.Id" class="col-lg-3">
            <div class="col-md-6">
                <div class="col-12 p-1" style="border:1px solid #008cba; border-radius: 5px;">
                    <div class="card">
                        <img src="@livre.ImageUrl" class="card-img-top rounded">
                        <div class="pl-1 card-body">
                            <p class="card-title text-primary">@livre.Titre</p>
                            <p class="card-title text-secondary">@livre.Auteur</p>
                            <p class="card-title text-info">@livre.Prix.ToString("0.00")</p>
                        </div>
                    </div>
                </div>
               
            </div>
        </a>
    }
</div>
