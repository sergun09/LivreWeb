@model IEnumerable<LivreWeb.Models.CouvertureType>

@{
    ViewData["Title"] = "Index";
}

<div class="pt-4">
    <div class="row">
        <div class="col-6">
            <h1>Liste des Couvertures</h1>  
        </div>
        <div class="col-6 text-end">
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle-dotted"></i> &nbsp; Ajouter une Couverture</a>  
        </div>
    </div>
</div>


<table class="table table-bordered table-striped pt-3">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nom)
            </th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nom)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">Modifier</a> |
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary">Voir</a> |
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Supprimer</a>
            </td>
        </tr>
}
    </tbody>
</table>
