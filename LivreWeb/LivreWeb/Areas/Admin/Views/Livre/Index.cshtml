@{
    ViewData["Title"] = "Index";
}

<div class="pt-4">
    <div class="row">
        <div class="col-6">
            <h1>Liste des Livres</h1>  
        </div>
        <div class="col-6 text-end">
            <a asp-action="Upsert" class="btn btn-primary"><i class="bi bi-plus-circle-dotted"></i> &nbsp; Ajouter un Livre</a>  
        </div>
    </div>
</div>


<table class="table table-bordered table-striped pt-3">
    <thead>
        <tr>
            <th>Titre</th>
            <th>ISBN</th>
            <th>Autheur</th>
            <th>Prix</th>
            <th>Titre</th>
        </tr>
    </thead>
    <tbody>
    </tbody>
</table>
