@model IEnumerable<LivreWeb.Models.Entreprise>

@{
    ViewData["Title"] = "Index";
}

<div class="pt-4">
    <div class="row">
        <div class="col-6">
            <h1>Liste des Entreprise</h1>  
        </div>
        <div class="col-6 text-end">
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle-dotted"></i> &nbsp; Ajouter une Entreprise</a>  
        </div>
    </div>
</div>


<table class="table table-bordered table-striped pt-3">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Adresse)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CodePostal)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Ville)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Departement)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Numero)
            </th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Adresse)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CodePostal)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Ville)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Departement)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Numero)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">Modifier</a> |
                <form asp-action="Delete" asp-route-id="@item.Id" onclick="return confirm('Voulez-vous vraiment supprimer la société @item.Name')">
                    <button type="submit" class="btn btn-danger" value="Supprimer" />Supprimer<button></button>
                </form>|
            </td>
        </tr>
}
    </tbody>
</table>
